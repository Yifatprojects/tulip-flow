# Copy to `.env.local` or `.env` and fill in values from the Supabase dashboard (Settings → API).
# This project is Vite: either prefix works (see vite.config.js envPrefix).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Label shown in authenticator apps when users enroll MFA (e.g. tulip-flow.vercel.app)
VITE_MFA_ISSUER=tulip-flow.vercel.app

# Add this URL in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
# https://your-domain.vercel.app/reset-password

# Optional: same variables using Next-style names (supported for Vercel parity)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
